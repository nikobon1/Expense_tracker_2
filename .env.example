# Локальная разработка
# Скопируйте этот файл в .env.local и заполните значения

# Neon Database URL (получите на https://neon.tech)
# Then run: npm run db:migrate
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# AI API ключ (один из двух)
OPENAI_API_KEY=your_openai_key_here
# или
GOOGLE_API_KEY=your_google_key_here

# Telegram bot (Railway)
TELEGRAM_BOT_TOKEN=123456789:telegram_bot_token
# Comma-separated list of Telegram user IDs allowed to use the bot
TELEGRAM_ALLOWED_USER_IDS=123456789
# Optional secret header validation for Telegram webhook
TELEGRAM_WEBHOOK_SECRET=change_me_random_secret
# Local helper for webhook setup script
WEBHOOK_BASE_URL=https://your-app.up.railway.app

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change_me_nextauth_secret
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Temporary staging-only login via Credentials provider
# Set to true only in staging/testing environments.
DEV_LOGIN_ENABLED=false
DEV_LOGIN_EMAIL=dev@local.test
DEV_LOGIN_NAME=Dev User
# Required when DEV_LOGIN_ENABLED=true. If empty, Dev Login stays disabled.
DEV_LOGIN_PASSWORD=change_me_dev_login_password
